      "title": "3h Energy (Wh)",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 5,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-measurement"
      },
      "options": {
        "barWidth": 0.97,
        "showValue": "auto",
        "orientation": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watth",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Field"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "hidden"
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "mean"
            ]
          }
        },
        {
          "id": "transpose",
          "options": {}
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-measurement"
          },
          "expr": "sum_over_time(avg_over_time(avg(scaph_host_power_microwatts)[1h:1h])[3h:1h]) / 1e6",
          "legendFormat": "3h"
        }
      ]
