{
  "uid": "green-benchmark-host",
  "title": "Host \u2014 Energy & Measurement Infrastructure",
  "description": "Host power consumption and measurement tool overhead. Part of green-observability-benchmark.",
  "tags": [
    "green",
    "scaphandre",
    "host",
    "benchmark"
  ],
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "2h",
      "1d"
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Host Power Overview",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Host Power (now)",
      "description": "Total host power consumption reported by Scaphandre via RAPL",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-measurement"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-measurement"
          },
          "expr": "scaph_host_power_microwatts / 1e6",
          "instant": true,
          "legendFormat": "Host power"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Load Average (1m)",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-measurement"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 8
              },
              {
                "color": "red",
                "value": 16
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-measurement"
          },
          "expr": "scaph_host_load_avg_one",
          "instant": true,
          "legendFormat": "1m load"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memory Available",
      "gridPos": {
        "x": 7,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-measurement"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 4000000000
              },
              {
                "color": "green",
                "value": 8000000000
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-measurement"
          },
          "expr": "scaph_host_memory_available_bytes",
          "instant": true,
          "legendFormat": "Available"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Top Consumer (now)",
      "gridPos": {
        "x": 10,
        "y": 1,
        "w": 7,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-measurement"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-measurement"
          },
          "expr": "topk(1, sum by (exe) (scaph_process_power_consumption_microwatts) / 1e6)",
          "instant": true,
          "legendFormat": "{{exe}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Scaphandre Version",
      "gridPos": {
        "x": 17,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-measurement"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-measurement"
          },
          "expr": "scaph_self_version",
          "instant": true,
          "legendFormat": "v{{version}}"
        }
