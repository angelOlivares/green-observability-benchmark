    {
      "id": 8,
      "type": "timeseries",
      "title": "Host Power Over Time",
      "description": "Total host power consumption in watts. Baseline for all experiment conditions.",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-measurement"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 2,
          "min": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-measurement"
          },
          "expr": "scaph_host_power_microwatts / 1e6",
          "legendFormat": "Host power (W)"
        }
      ]
